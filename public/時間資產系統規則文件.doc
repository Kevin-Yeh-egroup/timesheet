  td { padding: 5px 10px; border: 1px solid #e5e7eb; vertical-align: top; }
  tr:nth-child(even) td { background: #f9fafb; }
  .good { color: #16a34a; font-weight: 600; }
  .bad { color: #dc2626; font-weight: 600; }
  .badge { display: inline-block; background: #eff6ff; color: #1e40af; border-radius: 4px; padding: 1px 7px; font-size: 9pt; font-weight: 600; }
  .badge-green { background: #f0fdf4; color: #16a34a; }
  .badge-orange { background: #fff7ed; color: #ea580c; }
  .badge-purple { background: #faf5ff; color: #7c3aed; }
  .badge-amber { background: #fffbeb; color: #d97706; }
  .badge-teal { background: #f0fdfa; color: #0d9488; }
  .code { font-family: "Consolas", "Courier New", monospace; background: #f1f5f9; border: 1px solid #e2e8f0; border-radius: 3px; padding: 8px 12px; font-size: 9pt; color: #1e293b; white-space: pre; line-height: 1.6; margin: 8px 0; display: block; }
  .highlight { background: #eff6ff; border: 1px solid #bfdbfe; border-radius: 6px; padding: 10px 14px; margin: 10px 0; }
  .warning { background: #fef3c7; border: 1px solid #fcd34d; border-radius: 6px; padding: 10px 14px; margin: 10px 0; color: #92400e; }
