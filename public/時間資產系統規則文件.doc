  .cap-grid { display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 10px; margin: 10px 0; }
  .cap-card { border: 1px solid #e2e8f0; border-radius: 6px; padding: 10px 12px; background: #f8fafc; }
  .cap-name { font-weight: 700; font-size: 10pt; color: #1e40af; }
  .cap-detail { font-size: 9pt; color: #6b7280; margin-top: 3px; }
  .footer { margin-top: 40px; padding-top: 12px; border-top: 1px solid #e5e7eb; color: #9ca3af; font-size: 9pt; }
  .toc-item { margin: 4px 0; color: #1e40af; }
  .section-num { color: #6b7280; margin-right: 8px; }
</style>
