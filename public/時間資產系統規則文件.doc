    font-size: 10.5pt;
    line-height: 1.8;
  }
  h1 { font-size: 20pt; color: #1e40af; margin-bottom: 4px; border-bottom: 3px solid #1e40af; padding-bottom: 6px; }
  h2 { font-size: 14pt; color: #1e40af; margin-top: 28px; margin-bottom: 8px; border-bottom: 1.5px solid #bfdbfe; padding-bottom: 4px; }
  h3 { font-size: 11.5pt; color: #1d4ed8; margin-top: 18px; margin-bottom: 6px; }
